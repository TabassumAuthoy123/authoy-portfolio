/* ===== Mostaim-inspired Premium Portfolio ===== */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap');

*,
*::before,
*::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box
}

:root {
  --bg: 210 20% 98%;
  --fg: 222 47% 11%;
  --card: 0 0% 100%;
  --card-fg: 222 47% 11%;
  --muted: 210 20% 92%;
  --muted-fg: 215 16% 47%;
  --primary: 262 83% 58%;
  --primary-fg: 0 0% 100%;
  --accent: 280 70% 65%;
  --accent-fg: 0 0% 100%;
  --border: 210 20% 90%;
  --ring: 262 83% 58%;
  --radius: 0.75rem;
  --font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  --font-serif: 'Playfair Display', serif;
}

[data-theme="dark"] {
  --bg: 222 47% 10%;
  --fg: 210 40% 98%;
  --card: 222 40% 14%;
  --card-fg: 210 40% 98%;
  --muted: 222 30% 18%;
  --muted-fg: 215 20% 65%;
  --primary: 262 80% 65%;
  --primary-fg: 0 0% 100%;
  --accent: 280 70% 70%;
  --accent-fg: 0 0% 100%;
  --border: 222 25% 22%;
  --ring: 262 80% 65%;
}

html {
  scroll-behavior: smooth;
  scroll-padding-top: 80px;
}

body {
  font-family: var(--font);
  background: hsl(var(--bg));
  color: hsl(var(--fg));
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
  transition: background-color 0.3s ease, color 0.3s ease;
}

a {
  color: inherit;
  text-decoration: none;
}

ul,
ol {
  list-style: none;
}

img {
  max-width: 100%;
  display: block;
}

/* ===== Gradients & Effects ===== */
.hero-gradient {
  background: linear-gradient(135deg, #e8e0f3 0%, #f0f4f8 40%, #f8fafc 100%);
}

[data-theme="dark"] .hero-gradient {
  background: linear-gradient(135deg, #1f0f3d 0%, #0c0c12 40%, #0c0c12 100%);
}

.text-gradient {
  background: linear-gradient(90deg, #3b82f6, #60a5fa);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

[data-theme="dark"] .text-gradient {
  background: linear-gradient(90deg, #60a5fa, #2dd4bf);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.text-gradient-accent {
  background: linear-gradient(90deg, hsl(var(--accent)), #9333ea);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

[data-theme="dark"] .text-gradient-accent {
  background: linear-gradient(90deg, hsl(var(--accent)), #2dd4bf);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.glow-primary {
  box-shadow: 0 0 40px rgba(150, 150, 150, 0.15);
}

.glow-accent {
  box-shadow: 0 0 40px rgba(150, 150, 150, 0.15);
}

[data-theme="dark"] .glow-primary {
  box-shadow: 0 0 30px rgba(150, 150, 150, 0.15);
}

[data-theme="dark"] .glow-accent {
  box-shadow: 0 0 30px rgba(150, 150, 150, 0.15);
}

/* ===== Container ===== */
.container {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 2rem;
}

/* ===== Top Bar (Logo + Actions) ===== */
.nav-top {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  transition: all 0.3s ease;
  padding: 10px 0;
}

.nav-top--scrolled {
  background: rgba(150, 150, 150, 0.15);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-bottom: 1px solid rgba(150, 150, 150, 0.15);
}

.nav-top__inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 1rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 55px;
}

/* Logo */
.nav__logo {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 1.25rem;
  font-weight: 800;
  letter-spacing: -0.04em;
  flex-shrink: 0;
  text-decoration: none;
}

.nav__logo-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border-radius: 10px;
  background: rgba(150, 150, 150, 0.15);
  color: hsl(var(--primary));
  font-size: 1rem;
}

.nav__logo-text {
  color: hsl(var(--fg));
}

/* Right Actions */
.nav__actions {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}

.nav__action-pill {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  border-radius: 10px;
  border: 1px solid transparent;
  background: linear-gradient(to right, #3b82f6, #2dd4bf);
  font-size: 0.82rem;
  font-weight: 600;
  color: #fff;
  transition: all 0.3s ease;
  white-space: nowrap;
  text-decoration: none;
  font-family: var(--font);
  box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.06);
}

.nav__action-pill svg {
  color: #fff;
}

.nav__action-pill:hover {
  transform: scale(1.05);
  box-shadow: 0 0 2rem -0.5rem #60A5FA;
}

.nav__action-pill:active {
  transform: scale(0.98);
}

.nav__action-pill:hover svg {
  color: #fff;
}

.nav__action-icon {
  width: 38px;
  height: 38px;
  border-radius: 10px;
  border: 1px solid transparent;
  background: linear-gradient(to right, #3b82f6, #2dd4bf);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  transition: all 0.3s ease;
  cursor: pointer;
  box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.06);
}

.nav__action-icon:hover {
  transform: scale(1.05);
  box-shadow: 0 0 2rem -0.5rem #60A5FA;
}

.nav__action-icon svg {
  transition: transform 0.3s ease;
}

/* Dark theme overrides no longer needed â€” using fixed gradient */

/* CTA Button */
.nav__cta {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 22px;
  border-radius: 12px;
  font-size: 0.82rem;
  font-weight: 600;
  font-family: var(--font);
  background: linear-gradient(to right, #3b82f6, #2dd4bf);
  color: #fff;
  box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.06);
  transition: all 0.3s ease;
  white-space: nowrap;
  text-decoration: none;
  border: none;
  cursor: pointer;
}

.nav__cta:hover {
  transform: scale(1.05);
  box-shadow: 0 0 2rem -0.5rem #60A5FA;
}

/* ===== Floating Pill Navbar (Reference Style) ===== */
.nav-floating {
  position: fixed;
  top: 1.25rem;
  left: 50%;
  transform: translateX(-72%);
  z-index: 101;
  display: flex;
  align-items: center;
}

.nav-floating__pill {
  display: flex;
  gap: 2px;
  padding: 6px;
  border-radius: 999px;
  background: rgba(150, 150, 150, 0.15);
  backdrop-filter: blur(16px) saturate(180%);
  -webkit-backdrop-filter: blur(16px) saturate(180%);
  border: 1px solid rgba(150, 150, 150, 0.15);
  box-shadow:
    0 8px 32px rgba(150, 150, 150, 0.15),
    0 0 0 1px rgba(150, 150, 150, 0.15);
}

[data-theme="dark"] .nav-floating__pill {
  background: rgba(0, 0, 0, 0.5);
  box-shadow:
    0 8px 32px rgba(0, 0, 0, 0.3),
    0 0 0 1px rgba(255, 255, 255, 0.03);
}

.nav-floating__link {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 8px 12px;
  border-radius: 999px;
  font-size: 0.76rem;
  font-weight: 500;
  color: rgba(150, 150, 150, 0.15);
  transition: all 0.3s ease-in-out;
  cursor: pointer;
  background: transparent;
  border: none;
  font-family: var(--font);
  white-space: nowrap;
}

[data-theme="dark"] .nav-floating__link {
  color: rgba(209, 213, 219, 0.8);
}

.nav-floating__link svg {
  opacity: 0.7;
  transition: opacity 0.3s ease;
}

.nav-floating__link:hover {
  color: hsl(var(--primary));
  background: rgba(150, 150, 150, 0.15);
}

[data-theme="dark"] .nav-floating__link:hover {
  color: #fff;
  background: rgba(255, 255, 255, 0.1);
}

.nav-floating__link:hover svg {
  opacity: 1;
}

.nav-floating__link:active {
  transform: scale(0.96);
}

.nav-floating__link--active {
  color: #fff;
  background: rgba(255, 255, 255, 0.15);
  font-weight: 600;
}

.nav-floating__link--active svg {
  opacity: 1;
}

.nav-floating__link--active:hover {
  background: rgba(255, 255, 255, 0.2);
}

.nav-floating__list {
  background: rgba(150, 150, 150, 0.15);
  backdrop-filter: blur(16px);
  border: 1px solid rgba(150, 150, 150, 0.15);
  color: hsl(var(--fg));
  cursor: pointer;
  padding: 10px;
  border-radius: 50%;
}

[data-theme="dark"] .nav-floating__list {
  background: rgba(0, 0, 0, 0.5);
  border-color: rgba(59, 130, 246, 0.2);
  color: #d1d5db;
}

/* Mobile toggle for floating nav */
.nav-floating__toggle {
  display: none;
  background: rgba(150, 150, 150, 0.15);
  backdrop-filter: blur(16px);
  border: 1px solid rgba(150, 150, 150, 0.15);
  color: hsl(var(--fg));
  cursor: pointer;
  padding: 10px;
  border-radius: 50%;
}

[data-theme="dark"] .nav-floating__toggle {
  background: rgba(0, 0, 0, 0.5);
  border-color: rgba(59, 130, 246, 0.2);
  color: #d1d5db;
}

/* ===== CV Download Button (Hero) ===== */
.btn--download {
  background: linear-gradient(135deg, hsl(var(--primary)), hsl(var(--accent)));
  color: #fff;
  box-shadow: 0 4px 15px rgba(150, 150, 150, 0.15), 0 4px 15px rgba(150, 150, 150, 0.15);
  position: relative;
  overflow: hidden;
}

.btn--download::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, hsl(var(--accent)), hsl(var(--primary)));
  opacity: 0;
  transition: opacity 0.3s ease;
}

.btn--download:hover::before {
  opacity: 1;
}

.btn--download:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 25px rgba(150, 150, 150, 0.15), 0 6px 25px rgba(150, 150, 150, 0.15);
}

.btn--download span,
.btn--download svg {
  position: relative;
  z-index: 1;
}

/* ===== Section Common ===== */
.section {
  padding: 100px 0;
  position: relative;
}

.section__badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 16px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 999px;
  font-size: 0.82rem;
  font-weight: 600;
  color: hsl(var(--primary));
  margin-bottom: 20px;
}

.section__title {
  font-size: 2.5rem;
  font-weight: 800;
  letter-spacing: -0.03em;
  line-height: 1.15;
  margin-bottom: 16px;
}

.section__subtitle {
  font-size: 1.05rem;
  color: hsl(var(--muted-fg));
  line-height: 1.8;
  max-width: 600px;
}

/* ===== About Section (Mostaim-style) ===== */
.about__grid {
  display: grid;
  grid-template-columns: 45% 1fr;
  gap: 60px;
  align-items: start;
}

/* Left Column â€” Image + Stats */
.about__image-col {
  position: relative;
}

.about__image-wrapper {
  border-radius: 24px;
  overflow: hidden;
  position: relative;
  aspect-ratio: 4 / 5;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
}

[data-theme="dark"] .about__image-wrapper {
  background: rgba(255, 255, 255, 0.03);
  border-color: rgba(255, 255, 255, 0.06);
}

.about__photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.about__photo:hover {
  transform: scale(1.03);
}

.about__photo-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 6rem;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.08), rgba(45, 212, 191, 0.08));
}

/* Stats overlay bar */
.about__stats-bar {
  position: absolute;
  bottom: -30px;
  left: 50%;
  transform: translateX(-50%);
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2px;
  background: rgba(150, 150, 150, 0.15);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 20px;
  padding: 16px 8px;
  border: 1px solid rgba(150, 150, 150, 0.15);
  width: 92%;
  box-shadow: 0 8px 32px rgba(150, 150, 150, 0.15);
}

[data-theme="dark"] .about__stats-bar {
  background: rgba(10, 20, 40, 0.6);
  border-color: rgba(255, 255, 255, 0.08);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}

.about__stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 8px 4px;
  text-align: center;
}

.about__stat-icon {
  font-size: 1.1rem;
  color: #2dd4bf;
  margin-bottom: 2px;
}

.about__stat-value {
  font-size: 0.95rem;
  font-weight: 700;
  color: hsl(var(--fg));
}

[data-theme="dark"] .about__stat-value {
  color: #f3f4f6;
}

.about__stat-label {
  font-size: 0.72rem;
  font-weight: 500;
  color: hsl(var(--muted-fg));
}

[data-theme="dark"] .about__stat-label {
  color: rgba(209, 213, 219, 0.6);
}

/* Right Column â€” Text */
.about__text-col {
  padding-top: 10px;
}

.about__heading {
  font-size: 2.8rem;
  font-weight: 800;
  letter-spacing: -0.03em;
  line-height: 1.15;
  margin-bottom: 24px;
  color: hsl(var(--fg));
}

[data-theme="dark"] .about__heading {
  color: #f3f4f6;
}

.about__quote {
  position: relative;
  padding-left: 20px;
  margin-bottom: 28px;
  border-left: 3px solid #2dd4bf;
  font-style: italic;
  font-size: 1.05rem;
  font-weight: 500;
  line-height: 1.7;
  color: #2dd4bf;
}

.about__paragraph {
  font-size: 0.95rem;
  font-weight: 400;
  line-height: 1.8;
  color: hsl(var(--muted-fg));
  margin-bottom: 18px;
}

[data-theme="dark"] .about__paragraph {
  color: rgba(209, 213, 219, 0.8);
}

.about__cta-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-top: 10px;
  font-size: 0.95rem;
  font-weight: 600;
  color: #2dd4bf;
  text-decoration: underline;
  text-underline-offset: 4px;
  transition: all 0.3s ease;
}

.about__cta-link:hover {
  color: #5eead4;
  gap: 12px;
}

.about__cta-arrow {
  transition: transform 0.3s ease;
  font-size: 0.85rem;
}

.about__cta-link:hover .about__cta-arrow {
  transform: translateX(4px);
}

/* ===== Skills Section (Asif-style) ===== */

/* Icon Cloud */
.skills__cloud-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 50px;
  position: relative;
  perspective: 800px;
  min-height: 340px;
  cursor: grab;
}

.skills__cloud-wrapper::before {
  content: '';
  position: absolute;
  width: 300px;
  height: 300px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(59, 130, 246, 0.06) 0%, transparent 70%);
  pointer-events: none;
}

.skills__cloud-sphere {
  position: relative;
  width: 340px;
  height: 340px;
  transform-style: preserve-3d;
}

.skills__cloud-icon {
  position: absolute;
  left: 50%;
  top: 50%;
  margin-left: -14px;
  margin-top: -14px;
  will-change: transform, opacity;
  filter: drop-shadow(0 0 6px currentColor);
  transition: filter 0.3s ease;
}

.skills__cloud-icon:hover {
  filter: drop-shadow(0 0 14px currentColor);
}

.skills__cloud-canvas {
  cursor: grab;
  border-radius: 50%;
}

/* Skills Grid */
.skills__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.skills__card {
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 20px;
  padding: 28px 24px;
  transition: all 0.3s ease;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

[data-theme="dark"] .skills__card {
  background: rgba(10, 20, 40, 0.5);
  border-color: rgba(255, 255, 255, 0.06);
}

.skills__card:hover {
  border-color: hsl(var(--primary));
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(150, 150, 150, 0.15);
}

[data-theme="dark"] .skills__card:hover {
  border-color: rgba(59, 130, 246, 0.2);
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
}

.skills__card-header {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 22px;
}

.skills__card-icon-box {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(45, 212, 191, 0.15));
  border: 1px solid rgba(59, 130, 246, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #60a5fa;
  flex-shrink: 0;
}

.skills__card-title {
  font-size: 1.15rem;
  font-weight: 400;
  color: hsl(var(--muted-fg));
  letter-spacing: -0.01em;
}

[data-theme="dark"] .skills__card-title {
  color: rgba(209, 213, 219, 0.9);
}

.skills__card-title strong {
  font-weight: 700;
  color: hsl(var(--fg));
}

[data-theme="dark"] .skills__card-title strong {
  color: #f3f4f6;
}

.skills__pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.skills__pill {
  --pill-color: #60a5fa;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 8px 16px;
  border-radius: 999px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  font-size: 0.82rem;
  font-weight: 500;
  color: hsl(var(--fg));
  transition: all 0.3s ease;
  cursor: default;
}

[data-theme="dark"] .skills__pill {
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(255, 255, 255, 0.08);
  color: rgba(209, 213, 219, 0.85);
}

.skills__pill:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: var(--pill-color);
  color: #fff;
  transform: translateY(-2px);
  box-shadow: 0 4px 20px -6px var(--pill-color);
}

.skills__pill-icon {
  display: flex;
  align-items: center;
  font-size: 1rem;
  transition: transform 0.3s ease;
}

.skills__pill:hover .skills__pill-icon {
  transform: scale(1.2);
}


/* ===== Projects Section (Asif-style Sticky Stack) ===== */
.projects__stack {
  display: flex;
  flex-direction: column;
  gap: 30px;
  margin-top: 60px;
  padding-bottom: 60px;
}

.project-stack-card {
  position: sticky;
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 22px;
  overflow: hidden;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  transition: box-shadow 0.4s ease, border-color 0.4s ease;
}

[data-theme="dark"] .project-stack-card {
  background: rgba(10, 20, 40, 0.65);
  border-color: rgba(255, 255, 255, 0.06);
}

.project-stack-card:hover {
  border-color: rgba(255, 255, 255, 0.12);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
}

/* Image panel */
.project-stack-card__image {
  position: relative;
  overflow: hidden;
  min-height: 340px;
}

.project-stack-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.project-stack-card:hover .project-stack-card__image img {
  transform: scale(1.05);
}

.project-stack-card__badge {
  position: absolute;
  top: 16px;
  left: 16px;
  background: rgba(150, 150, 150, 0.15);
  backdrop-filter: blur(8px);
  color: hsl(var(--fg));
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  padding: 6px 14px;
  border-radius: 8px;
  border: 1px solid rgba(150, 150, 150, 0.15);
  z-index: 2;
}

[data-theme="dark"] .project-stack-card__badge {
  background: rgba(0, 0, 0, 0.65);
  color: rgba(255, 255, 255, 0.9);
  border-color: rgba(255, 255, 255, 0.1);
}

/* Content panel */
.project-stack-card__content {
  padding: 40px 36px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* Accent dot + line */
.project-stack-card__accent {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 18px;
}

.project-stack-card__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}

.project-stack-card__line {
  height: 1.5px;
  width: 50px;
  background: rgba(255, 255, 255, 0.15);
}

.project-stack-card__title {
  font-size: 1.6rem;
  font-weight: 700;
  color: hsl(var(--fg));
  margin-bottom: 4px;
  letter-spacing: -0.02em;
}

[data-theme="dark"] .project-stack-card__title {
  color: #f3f4f6;
}

.project-stack-card__subtitle {
  font-size: 0.9rem;
  color: hsl(var(--muted-fg));
  margin-bottom: 14px;
  font-weight: 500;
}

[data-theme="dark"] .project-stack-card__subtitle {
  color: rgba(156, 163, 175, 0.8);
}

.project-stack-card__desc {
  font-size: 0.88rem;
  color: hsl(var(--muted-fg));
  line-height: 1.65;
  margin-bottom: 22px;
}

[data-theme="dark"] .project-stack-card__desc {
  color: rgba(156, 163, 175, 0.7);
}

/* Tech stack pills */
.project-stack-card__tech {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 24px;
}

.project-stack-card__tag {
  padding: 5px 14px;
  border-radius: 999px;
  font-size: 0.75rem;
  font-weight: 500;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  color: hsl(var(--muted-fg));
  letter-spacing: 0.02em;
}

[data-theme="dark"] .project-stack-card__tag {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.08);
  color: rgba(209, 213, 219, 0.8);
}

/* Action links */
.project-stack-card__links {
  display: flex;
  gap: 20px;
  margin-top: auto;
}

.project-stack-card__link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.88rem;
  font-weight: 600;
  text-decoration: none;
  transition: opacity 0.25s ease;
}

.project-stack-card__link:hover {
  opacity: 0.75;
}

/* ===== Journey Section (Asif-style Education + Experience) ===== */
.journey__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30px;
  margin-top: 50px;
}

.journey__box {
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 20px;
  padding: 30px;
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
}

[data-theme="dark"] .journey__box {
  background: rgba(10, 20, 40, 0.5);
  border-color: rgba(255, 255, 255, 0.06);
}

.journey__box-header {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 24px;
  padding-bottom: 18px;
  border-bottom: 1px solid rgba(150, 150, 150, 0.15);
}

[data-theme="dark"] .journey__box-header {
  border-bottom-color: rgba(255, 255, 255, 0.06);
}

.journey__box-icon {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.journey__box-title {
  font-size: 1.15rem;
  font-weight: 700;
  color: hsl(var(--fg));
}

[data-theme="dark"] .journey__box-title {
  color: #f3f4f6;
}

.journey__box-cards {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* â”€â”€ Individual Journey Card â”€â”€ */
.journey-card {
  --jc-accent: #60a5fa;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 16px;
  padding: 24px;
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

[data-theme="dark"] .journey-card {
  background: rgba(255, 255, 255, 0.03);
  border-color: rgba(255, 255, 255, 0.05);
}

.journey-card:hover {
  border-color: rgba(255, 255, 255, 0.1);
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
}

.journey-card__header {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 12px;
}

.journey-card__icon {
  font-size: 1.5rem;
  line-height: 1;
  flex-shrink: 0;
  margin-top: 2px;
}

.journey-card__role {
  font-size: 1.05rem;
  font-weight: 700;
  color: hsl(var(--fg));
  letter-spacing: -0.01em;
  line-height: 1.35;
}

[data-theme="dark"] .journey-card__role {
  color: #f3f4f6;
}

/* Meta row */
.journey-card__meta {
  display: flex;
  flex-direction: column;
  gap: 5px;
  margin-bottom: 16px;
}

.journey-card__meta-item {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.8rem;
  color: hsl(var(--muted-fg));
}

[data-theme="dark"] .journey-card__meta-item {
  color: rgba(156, 163, 175, 0.8);
}

.journey-card__meta-item svg {
  color: var(--jc-accent);
  flex-shrink: 0;
}

/* Summary blockquote */
.journey-card__summary {
  margin: 0 0 16px;
  padding: 12px 16px;
  border-left: 3px solid var(--jc-accent);
  background: rgba(150, 150, 150, 0.15);
  border-radius: 0 10px 10px 0;
  font-size: 0.82rem;
  font-style: italic;
  color: hsl(var(--muted-fg));
  line-height: 1.6;
}

[data-theme="dark"] .journey-card__summary {
  background: rgba(255, 255, 255, 0.02);
  color: rgba(209, 213, 219, 0.7);
}

/* Key Achievements */
.journey-card__achievements {
  margin-bottom: 16px;
}

.journey-card__ach-label {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.82rem;
  font-weight: 600;
  color: hsl(var(--fg));
  margin-bottom: 10px;
}

[data-theme="dark"] .journey-card__ach-label {
  color: rgba(209, 213, 219, 0.85);
}

.journey-card__ach-label svg {
  color: var(--jc-accent);
}

.journey-card__ach-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.journey-card__ach-pill {
  padding: 5px 14px;
  border-radius: 999px;
  font-size: 0.75rem;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid var(--jc-accent);
  color: var(--jc-accent);
}

[data-theme="dark"] .journey-card__ach-pill {
  background: rgba(255, 255, 255, 0.04);
}

.journey-card__ach-pill strong {
  font-weight: 700;
}

/* Bullet highlights (work) */
.journey-card__highlights {
  list-style: none;
  padding: 0;
  margin: 0 0 16px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.journey-card__highlights li {
  font-size: 0.82rem;
  color: hsl(var(--muted-fg));
  padding-left: 18px;
  position: relative;
  line-height: 1.55;
}

[data-theme="dark"] .journey-card__highlights li {
  color: rgba(209, 213, 219, 0.7);
}

.journey-card__highlights li::before {
  content: 'â–¹';
  position: absolute;
  left: 0;
  color: var(--jc-accent);
  font-weight: 700;
}

/* Subject tags */
.journey-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.journey-card__tag {
  padding: 4px 12px;
  border-radius: 8px;
  font-size: 0.7rem;
  font-weight: 500;
  background: rgba(59, 130, 246, 0.06);
  border: 1px solid rgba(59, 130, 246, 0.12);
  color: rgba(156, 163, 175, 0.7);
}

/* ===== Leadership Grid (full-width box) ===== */
.journey__grid--full {
  grid-template-columns: 1fr;
}

/* Ã¢â€â‚¬Ã¢â€â‚¬ Vertical Alternating Timeline (mostaim-style) Ã¢â€â‚¬Ã¢â€â‚¬ */
.vtl {
  position: relative;
  padding: 40px 0;
}

/* Center spine */
.vtl__line {
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 2px;
  background: linear-gradient(180deg, transparent, rgba(45, 212, 191, 0.35) 10%, rgba(45, 212, 191, 0.35) 90%, transparent);
  transform: translateX(-50%);
}

/* Each row */
.vtl__row {
  --vtl-accent: #2dd4bf;
  position: relative;
  display: flex;
  align-items: flex-start;
  margin-bottom: 50px;
  width: 100%;
}

.vtl__row:last-child {
  margin-bottom: 0;
}

/* Dot on the spine */
.vtl__dot {
  position: absolute;
  left: 50%;
  top: 16px;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: hsl(var(--card));
  border: 2px solid var(--vtl-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--vtl-accent);
  transform: translateX(-50%);
  z-index: 2;
  box-shadow: 0 0 10px rgba(150, 150, 150, 0.15);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

[data-theme="dark"] .vtl__dot {
  background: rgba(10, 20, 40, 0.95);
  box-shadow: 0 0 10px rgba(45, 212, 191, 0.1);
}

.vtl__row:hover .vtl__dot {
  transform: translateX(-50%) scale(1.1);
  box-shadow: 0 0 20px var(--vtl-accent);
}

/* Card */
.vtl__card {
  display: flex;
  gap: 16px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 16px;
  padding: 20px;
  width: calc(50% - 50px);
  transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
}

[data-theme="dark"] .vtl__card {
  background: rgba(255, 255, 255, 0.025);
  border-color: rgba(255, 255, 255, 0.06);
}

.vtl__row:hover .vtl__card {
  border-color: rgba(255, 255, 255, 0.12);
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
}

/* Left row */
.vtl__row--left .vtl__card {
  margin-right: auto;
}

.vtl__row--left:hover .vtl__card {
  transform: translateX(-4px);
}

/* Right row */
.vtl__row--right .vtl__card {
  margin-left: auto;
}

.vtl__row--right:hover .vtl__card {
  transform: translateX(4px);
}

/* Connector lines */
.vtl__row--left .vtl__card::after,
.vtl__row--right .vtl__card::after {
  content: '';
  position: absolute;
  top: 34px;
  height: 2px;
  background: var(--vtl-accent);
  opacity: 0.3;
}

.vtl__row--left .vtl__card::after {
  right: calc(50% - 20px);
  left: calc(50% - 50px);
  transform: none;
}

.vtl__row--right .vtl__card::after {
  left: calc(50% + 20px);
  right: calc(50% - 50px);
  transform: none;
}

/* Photo box */
.vtl__card-photo {
  width: 70px;
  height: 70px;
  border-radius: 12px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px dashed rgba(150, 150, 150, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(150, 150, 150, 0.15);
  flex-shrink: 0;
  overflow: hidden;
}

[data-theme="dark"] .vtl__card-photo {
  background: rgba(255, 255, 255, 0.03);
  border-color: rgba(255, 255, 255, 0.1);
  color: rgba(156, 163, 175, 0.25);
}

.vtl__card-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 12px;
}

/* Card body */
.vtl__card-body {
  flex: 1;
  min-width: 0;
}

.vtl__card-date {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 0.7rem;
  font-weight: 600;
  padding: 4px 12px;
  border-radius: 999px;
  background: rgba(45, 212, 191, 0.08);
  color: var(--vtl-accent);
  border: 1px solid rgba(45, 212, 191, 0.2);
  margin-bottom: 10px;
}

.vtl__card-role {
  font-size: 1.05rem;
  font-weight: 700;
  color: hsl(var(--fg));
  margin-bottom: 4px;
  line-height: 1.3;
}

[data-theme="dark"] .vtl__card-role {
  color: #f3f4f6;
}

.vtl__card-company {
  font-size: 0.82rem;
  color: var(--vtl-accent);
  font-weight: 500;
  margin-bottom: 6px;
}

.vtl__card-desc {
  font-size: 0.78rem;
  color: hsl(var(--muted-fg));
  line-height: 1.55;
}

[data-theme="dark"] .vtl__card-desc {
  color: rgba(156, 163, 175, 0.6);
}

/* Active row glow */
.vtl__row--active .vtl__dot {
  box-shadow: 0 0 18px var(--vtl-accent), 0 0 40px rgba(45, 212, 191, 0.2);
  animation: vtl-pulse 2.5s ease-in-out infinite;
}

.vtl__row--active .vtl__card {
  border-color: var(--vtl-accent);
  box-shadow: 0 0 24px rgba(45, 212, 191, 0.12), 0 4px 20px rgba(0, 0, 0, 0.25);
}

@keyframes vtl-pulse {

  0%,
  100% {
    box-shadow: 0 0 18px var(--vtl-accent), 0 0 40px rgba(45, 212, 191, 0.2);
  }

  50% {
    box-shadow: 0 0 28px var(--vtl-accent), 0 0 60px rgba(45, 212, 191, 0.3);
  }
}

/* Responsive */
@media (max-width: 768px) {
  .vtl__line {
    left: 20px;
  }

  .vtl__dot {
    left: 20px;
    width: 34px;
    height: 34px;
  }

  .vtl__row--left .vtl__card,
  .vtl__row--right .vtl__card {
    width: calc(100% - 60px);
    margin-left: auto;
    margin-right: 0;
  }

  .vtl__row--left .vtl__card::after,
  .vtl__row--right .vtl__card::after {
    display: none;
  }
}

/* ===== Achievements â€” Professional Two-Column ===== */
.ach__layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30px;
  margin-top: 50px;
  align-items: stretch;
}

.ach__column {
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 20px;
  padding: 30px;
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
}

[data-theme="dark"] .ach__column {
  background: rgba(10, 20, 40, 0.5);
  border-color: rgba(255, 255, 255, 0.06);
}

.ach__col-header {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 24px;
  padding-bottom: 18px;
  border-bottom: 1px solid rgba(150, 150, 150, 0.15);
}

[data-theme="dark"] .ach__col-header {
  border-bottom-color: rgba(255, 255, 255, 0.06);
}

.ach__col-icon {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ach__col-title {
  font-size: 1.15rem;
  font-weight: 700;
  color: hsl(var(--fg));
}

[data-theme="dark"] .ach__col-title {
  color: #f3f4f6;
}

/* -- Vertical mini-timeline for competitions -- */
.ach__timeline {
  position: relative;
  padding-left: 24px;
}

.ach__timeline::before {
  content: '';
  position: absolute;
  left: 5px;
  top: 0;
  bottom: 0;
  width: 2px;
  background: linear-gradient(180deg, rgba(249, 115, 22, 0.4) 0%, rgba(59, 130, 246, 0.25) 100%);
  border-radius: 2px;
}

.ach__tl-item {
  --ach-accent: #F97316;
  position: relative;
  margin-bottom: 22px;
}

.ach__tl-item:last-child {
  margin-bottom: 0;
}

.ach__tl-dot {
  position: absolute;
  left: -22px;
  top: 6px;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--ach-accent);
  box-shadow: 0 0 10px var(--ach-accent);
}

.ach__tl-card {
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 14px;
  padding: 18px;
  transition: border-color 0.3s ease, transform 0.3s ease;
}

[data-theme="dark"] .ach__tl-card {
  background: rgba(255, 255, 255, 0.025);
  border-color: rgba(255, 255, 255, 0.05);
}

.ach__tl-card:hover {
  border-color: rgba(255, 255, 255, 0.1);
  transform: translateX(4px);
}

.ach__tl-card-top {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  margin-bottom: 6px;
}

.ach__tl-badge {
  font-size: 1.2rem;
  line-height: 1;
  flex-shrink: 0;
}

.ach__tl-title {
  font-size: 0.92rem;
  font-weight: 700;
  color: hsl(var(--fg));
  line-height: 1.3;
}

[data-theme="dark"] .ach__tl-title {
  color: #f3f4f6;
}

.ach__tl-org {
  font-size: 0.76rem;
  color: var(--ach-accent);
  margin-bottom: 6px;
  font-weight: 500;
}

.ach__tl-desc {
  font-size: 0.76rem;
  color: hsl(var(--muted-fg));
  line-height: 1.5;
  margin-bottom: 8px;
}

[data-theme="dark"] .ach__tl-desc {
  color: rgba(156, 163, 175, 0.65);
}

.ach__tl-date {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 0.68rem;
  font-weight: 600;
  padding: 3px 10px;
  border-radius: 999px;
  background: rgba(150, 150, 150, 0.15);
  color: hsl(var(--muted-fg));
  border: 1px solid rgba(150, 150, 150, 0.15);
}

[data-theme="dark"] .ach__tl-date {
  background: rgba(255, 255, 255, 0.04);
  color: rgba(209, 213, 219, 0.6);
  border-color: rgba(255, 255, 255, 0.06);
}

.ach__tl-date svg {
  color: var(--ach-accent);
}

/* -- CP Big Stat Card -- */
.ach__stat-card {
  text-align: center;
  padding: 22px 16px;
  background: rgba(45, 212, 191, 0.04);
  border: 1px solid rgba(45, 212, 191, 0.12);
  border-radius: 16px;
  margin-bottom: 12px;
}

.ach__stat-number {
  font-size: 2.8rem;
  font-weight: 800;
  background: linear-gradient(135deg, #60a5fa, #2dd4bf);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
}

.ach__stat-number span {
  font-size: 1.8rem;
}

.ach__stat-label {
  font-size: 0.9rem;
  font-weight: 700;
  color: hsl(var(--fg));
  margin-top: 6px;
}

[data-theme="dark"] .ach__stat-label {
  color: #f3f4f6;
}

.ach__stat-sub {
  font-size: 0.72rem;
  color: hsl(var(--muted-fg));
  margin-top: 3px;
}

[data-theme="dark"] .ach__stat-sub {
  color: rgba(156, 163, 175, 0.6);
}

/* Profile links â€” bottom-right corner */
.ach__column--right-full {
  display: flex;
  flex-direction: column;
}

.ach__inner-section {
  margin-top: 18px;
  padding-top: 18px;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}

.ach__inner-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 12px;
}

.ach__inner-title {
  font-size: 0.95rem;
  font-weight: 700;
  color: hsl(var(--fg));
}

[data-theme="dark"] .ach__inner-title {
  color: #f3f4f6;
}

.ach__profile-links {
  display: flex;
  justify-content: center;
  gap: 12px;
  margin-top: 18px;
}

.ach__profile-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 18px;
  border-radius: 10px;
  font-size: 0.78rem;
  font-weight: 600;
  text-decoration: none;
  color: #60a5fa;
  background: rgba(96, 165, 250, 0.08);
  border: 1px solid rgba(96, 165, 250, 0.18);
  transition: all 0.3s ease;
}

.ach__profile-link:hover {
  background: rgba(96, 165, 250, 0.16);
  border-color: rgba(96, 165, 250, 0.35);
  transform: translateY(-2px);
  box-shadow: 0 4px 16px rgba(96, 165, 250, 0.15);
}

.ach__profile-link--lc {
  color: #F59E0B;
  background: rgba(245, 158, 11, 0.08);
  border-color: rgba(245, 158, 11, 0.18);
}

.ach__profile-link--lc:hover {
  background: rgba(245, 158, 11, 0.16);
  border-color: rgba(245, 158, 11, 0.35);
  box-shadow: 0 4px 16px rgba(245, 158, 11, 0.15);
}

/* â”€â”€ Interests Row (kept for backward compat) â”€â”€ */
.ach__layout--interests {
  grid-template-columns: 1fr 1fr;
}

@media (max-width: 768px) {
  .ach__layout--interests {
    grid-template-columns: 1fr;
  }
}

.ach__interest-cards {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.ach__interest-card {
  --ach-accent: #3B82F6;
  display: flex;
  gap: 14px;
  align-items: flex-start;
  padding: 18px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 14px;
  transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
}

[data-theme="dark"] .ach__interest-card {
  background: rgba(255, 255, 255, 0.025);
  border-color: rgba(255, 255, 255, 0.06);
}

.ach__interest-emoji {
  font-size: 1.6rem;
  flex-shrink: 0;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(150, 150, 150, 0.15);
  border-radius: 10px;
}

[data-theme="dark"] .ach__interest-emoji {
  background: rgba(255, 255, 255, 0.04);
}

.ach__interest-title {
  font-size: 0.92rem;
  font-weight: 700;
  color: hsl(var(--fg));
  margin-bottom: 4px;
}

[data-theme="dark"] .ach__interest-title {
  color: #f3f4f6;
}

.ach__interest-org {
  font-size: 0.78rem;
  color: var(--ach-accent);
  font-weight: 500;
  margin-bottom: 4px;
}

.ach__interest-desc {
  font-size: 0.78rem;
  color: hsl(var(--muted-fg));
  line-height: 1.55;
}

[data-theme="dark"] .ach__interest-desc {
  color: rgba(156, 163, 175, 0.6);
}

.ach__interest-desc strong {
  color: hsl(var(--fg));
  font-weight: 600;
}

[data-theme="dark"] .ach__interest-desc strong {
  color: #f3f4f6;
}

/* ===== Hero (Dev Dark Theme) ===== */
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  background: hsl(var(--bg));
}

/* Grid background â€” matching reference exactly */
.hero__grid-bg {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(150, 150, 150, 0.15) 1px, transparent 1px),
    linear-gradient(90deg, rgba(150, 150, 150, 0.15) 1px, transparent 1px);
  background-size: 50px 50px;
  pointer-events: none;
  z-index: 0;
  mask-image: radial-gradient(ellipse at center, transparent 20%, black);
  -webkit-mask-image: radial-gradient(ellipse at center, transparent 20%, black);
}

[data-theme="dark"] .hero__grid-bg {
  background-image:
    linear-gradient(rgba(50, 50, 70, 0.15) 1px, transparent 1px),
    linear-gradient(90deg, rgba(50, 50, 70, 0.15) 1px, transparent 1px);
}

/* Ambient glows */
.hero__glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(120px);
  pointer-events: none;
  z-index: 0;
}

.hero__glow--1 {
  width: 500px;
  height: 500px;
  top: -10%;
  left: -5%;
  background: rgba(96, 165, 250, 0.06);
}

.hero__glow--2 {
  width: 400px;
  height: 400px;
  bottom: -10%;
  right: 5%;
  background: rgba(45, 212, 191, 0.05);
}

.hero__layout {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  align-items: center;
  gap: 3rem;
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
  padding: 140px 3rem 100px;
  position: relative;
  z-index: 1;
}

/* === Left Content === */
.hero__text {
  animation: heroSlideUp 0.7s ease-out forwards;
  position: relative;
}

@keyframes heroSlideUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Welcome badge */
.hero__welcome-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 18px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 999px;
  font-size: 0.82rem;
  font-weight: 500;
  color: hsl(var(--fg));
  margin-bottom: 28px;
  backdrop-filter: blur(10px);
}

[data-theme="dark"] .hero__welcome-badge {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.7);
}

.hero__welcome-dot {
  color: #60a5fa;
  font-size: 0.7rem;
}

/* Floating tags */
.hero__floating-tags {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280px;
  pointer-events: none;
  z-index: 2;
}

.hero__float-tag {
  position: absolute;
  padding: 6px 16px;
  border-radius: 10px;
  font-size: 0.78rem;
  font-weight: 600;
  border: 1px solid rgba(150, 150, 150, 0.15);
  background: rgba(150, 150, 150, 0.15);
  backdrop-filter: blur(12px);
  color: hsl(var(--fg));
  animation: floatTagSlow 7s ease-in-out infinite;
  pointer-events: auto;
  transition: all 0.3s ease;
}

[data-theme="dark"] .hero__float-tag {
  border-color: rgba(255, 255, 255, 0.05);
  background: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.85);
}

.hero__float-tag:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(96, 165, 250, 0.3);
  transform: translateY(-4px) scale(1.05);
  box-shadow: 0 0 2rem -0.5rem rgba(96, 165, 250, 0.3);
}

.hero__float-tag--1 {
  top: 60px;
  left: 120px;
  background: rgba(96, 165, 250, 0.1);
  border-color: rgba(96, 165, 250, 0.2);
  color: #60a5fa;
  animation-delay: 0s;
}

.hero__float-tag--2 {
  top: 25px;
  right: 20px;
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.8);
  animation-delay: 1.5s;
}

.hero__float-tag--3 {
  top: 170px;
  right: 40px;
  background: rgba(45, 212, 191, 0.08);
  border-color: rgba(45, 212, 191, 0.15);
  color: #2dd4bf;
  animation-delay: 3s;
}

@keyframes floatTagSlow {

  0%,
  100% {
    transform: translateY(0) rotate(1deg);
  }

  50% {
    transform: translateY(-10px) rotate(-1deg);
  }
}

/* Hero heading */
.hero__heading {
  font-family: var(--font);
  font-size: 3.4rem;
  font-weight: 900;
  letter-spacing: -0.025em;
  line-height: 1.1;
  margin-bottom: 20px;
  color: hsl(var(--fg));
}

[data-theme="dark"] .hero__heading {
  color: #f3f4f6;
}

.hero__hello-text {
  display: block;
  font-size: 3.6rem;
  margin-bottom: 0;
}

.hero__sparkle {
  color: #facc15;
  font-size: 1.2rem;
  margin-left: 4px;
  display: inline-block;
  animation: sparkleRotate 3s ease-in-out infinite;
}

@keyframes sparkleRotate {

  0%,
  100% {
    transform: rotate(0deg) scale(1);
  }

  50% {
    transform: rotate(15deg) scale(1.2);
  }
}

.hero__name-highlight {
  background: linear-gradient(90deg, #60a5fa, #2dd4bf);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Skill pill */
.hero__skill-pill {
  display: inline-flex;
  align-items: center;
  padding: 8px 22px;
  border-radius: 999px;
  font-size: 0.85rem;
  font-weight: 600;
  color: #2dd4bf;
  border: 1px solid rgba(45, 212, 191, 0.2);
  background: rgba(45, 212, 191, 0.1);
  margin-bottom: 20px;
}

/* Description */
.hero__desc {
  font-size: 0.95rem;
  color: hsl(var(--muted-fg));
  line-height: 1.8;
  margin-bottom: 30px;
  max-width: 460px;
}

[data-theme="dark"] .hero__desc {
  color: rgba(209, 213, 219, 0.9);
}

/* Social Buttons â€” matching reference gradient buttons */
.hero__social-btns {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
}

.hero__social-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 28px;
  border-radius: 12px;
  font-size: 0.88rem;
  font-weight: 600;
  color: #fff;
  border: 1px solid transparent;
  cursor: pointer;
  transition: all 0.3s ease;
  text-decoration: none;
  font-family: var(--font);
  position: relative;
  overflow: hidden;
}

/* Github â€” blue-to-teal gradient */
.hero__social-btn--github {
  background: linear-gradient(to right, #3b82f6, #2dd4bf);
  box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.06);
}

.hero__social-btn--github:hover {
  transform: scale(1.05);
  box-shadow: 0 0 2rem -0.5rem #60A5FA;
}

/* LinkedIn â€” gray gradient */
.hero__social-btn--linkedin {
  background: linear-gradient(to right, #1f2937, #374151);
  border: 1px solid rgba(255, 255, 255, 0.05);
  box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.06);
}

.hero__social-btn--linkedin:hover {
  transform: scale(1.05);
  box-shadow: 0 0 2rem -0.5rem #60A5FA;
  background: linear-gradient(to right, #1f2937, #374151);
}

/* === Right: Code Editor === */
.hero__editor-wrapper {
  animation: heroFadeIn 0.8s ease-out 0.3s both;
  position: relative;
}

@keyframes heroFadeIn {
  from {
    opacity: 0;
    transform: translateY(20px) scale(0.97);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.hero__editor {
  background: hsl(var(--card));
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 12px;
  overflow: hidden;
  box-shadow:
    0 0 20px rgba(150, 150, 150, 0.15),
    0 25px 50px -12px rgba(0, 0, 0, 0.1);
  position: relative;
  transition: all 0.3s ease;
}

[data-theme="dark"] .hero__editor {
  background: #091121;
  border-color: rgba(59, 130, 246, 0.2);
  box-shadow:
    0 0 20px rgba(16, 88, 149, 0.6),
    0 25px 50px -12px rgba(0, 0, 0, 0.25);
}

.hero__editor:hover {
  box-shadow:
    0 0 30px rgba(16, 88, 149, 0.8),
    0 25px 50px -12px rgba(0, 0, 0, 0.35);
  transform: scale(1.02);
}

.hero__editor::before {
  content: '';
  position: absolute;
  inset: -2px;
  border-radius: 13px;
  padding: 2px;
  background: linear-gradient(135deg, rgba(45, 212, 191, 0.3), rgba(56, 189, 248, 0.3));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
  z-index: 1;
}

.hero__editor-header {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 12px 16px;
  background: rgba(150, 150, 150, 0.15);
  border-bottom: 1px solid rgba(150, 150, 150, 0.15);
}

[data-theme="dark"] .hero__editor-header {
  background: rgba(11, 70, 99, 0.35);
  border-bottom-color: rgba(255, 255, 255, 0.06);
}

.hero__editor-dots {
  display: flex;
  gap: 7px;
}

.hero__dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  transition: transform 0.3s ease;
}

.hero__dot:hover {
  transform: scale(1.2);
}

.hero__dot--red {
  background: #ef4444;
}

.hero__dot--yellow {
  background: #eab308;
}

.hero__dot--green {
  background: #22c55e;
}

.hero__editor-filename {
  font-size: 0.82rem;
  color: rgba(255, 255, 255, 0.45);
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
}

.hero__editor-body {
  padding: 24px 28px;
  overflow-x: auto;
}

.hero__code {
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
  font-size: 0.95rem;
  line-height: 1.5;
  color: #ccc;
  margin: 0;
  white-space: pre;
  tab-size: 4;
}

/* Syntax highlighting â€” matching reference Prism theme */
.code-kw {
  color: #cc99cd;
}

.code-var {
  color: #f8c555;
}

.code-op {
  color: #ccc;
}

.code-key {
  color: #f8c555;
}

.code-str {
  color: #7ec699;
}

.code-bool {
  color: #f08d49;
}

.code-num {
  color: #f08d49;
}

.code-comment {
  color: #999;
  font-style: italic;
}

/* ===== Buttons ===== */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 28px;
  border-radius: var(--radius);
  font-size: 0.9rem;
  font-weight: 600;
  font-family: var(--font);
  cursor: pointer;
  transition: all 0.3s ease;
  border: none;
  outline: none;
  text-decoration: none;
}

.btn--primary {
  background: transparent;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  color: hsl(var(--primary));
  border: 1.5px solid rgba(150, 150, 150, 0.15);
  position: relative;
  overflow: visible;
  transition: all 0.3s ease;
  box-shadow: none;
}

.btn--primary:hover {
  background: rgba(150, 150, 150, 0.15);
  border-color: rgba(150, 150, 150, 0.15);
  transform: translateY(-2px);
  box-shadow: 0 8px 25px -5px rgba(150, 150, 150, 0.15);
}

.btn--primary:active {
  transform: scale(0.97);
  background: rgba(150, 150, 150, 0.15);
}

[data-theme="dark"] .btn--primary {
  border-color: rgba(150, 150, 150, 0.15);
  color: hsl(var(--primary));
}

[data-theme="dark"] .btn--primary:hover {
  background: rgba(150, 150, 150, 0.15);
  border-color: hsl(var(--primary));
}

/* Glowing Border effect */
.btn--primary::before {
  content: '';
  position: absolute;
  inset: -2px;
  padding: 2px;
  border-radius: inherit;
  background: linear-gradient(90deg,
      rgba(150, 150, 150, 0.15),
      rgba(150, 150, 150, 0.15),
      rgba(150, 150, 150, 0.15));
  background-size: 200% 100%;
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  animation: shine 3s linear infinite;
  opacity: 0.4;
}

@keyframes shine {
  to {
    background-position: 200% center;
  }
}

.btn--primary:hover {
  transform: translateY(-3px);
  background: rgba(150, 150, 150, 0.15);
  box-shadow: 0 12px 35px -8px rgba(150, 150, 150, 0.15);
}

.btn--primary:hover::before {
  opacity: 1;
  animation-duration: 1.5s;
}

.btn--outline {
  background: transparent;
  color: hsl(var(--fg));
  border: 1px solid rgba(150, 150, 150, 0.15);
}

.btn--outline:hover {
  border-color: rgba(150, 150, 150, 0.15);
  background: rgba(150, 150, 150, 0.15);
}

.btn--full {
  width: 100%;
  justify-content: center;
}

.btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none !important;
}

/* ===== About ===== */
.about__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

.about__image-area {
  position: relative;
}

.about__image-card {
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 16px;
  backdrop-filter: blur(4px);
  padding: 32px;
  position: relative;
}

.about__image-glow {
  position: absolute;
  inset: 0;
  border-radius: 16px;
  background: linear-gradient(135deg, rgba(150, 150, 150, 0.15), rgba(150, 150, 150, 0.15));
  z-index: -1;
  filter: blur(40px);
}

.about__image-placeholder {
  width: 100%;
  aspect-ratio: 4/5;
  border-radius: 12px;
  background: linear-gradient(135deg, rgba(150, 150, 150, 0.15), rgba(150, 150, 150, 0.15));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 6rem;
  position: relative;
  overflow: hidden;
}

.about__image-placeholder::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 60%, rgba(150, 150, 150, 0.15));
}

.about__text {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.about__text p {
  font-size: 1rem;
  color: hsl(var(--muted-fg));
  line-height: 1.85;
}

.about__highlight {
  display: flex;
  gap: 16px;
  margin-top: 12px;
}

.about__highlight-card {
  flex: 1;
  padding: 20px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 12px;
  text-align: center;
  transition: all 0.3s ease;
}

.about__highlight-card:hover {
  border-color: rgba(150, 150, 150, 0.15);
  box-shadow: 0 0 20px -5px rgba(150, 150, 150, 0.15);
  transform: translateY(-2px);
}

.about__highlight-value {
  font-size: 1.5rem;
  font-weight: 800;
  letter-spacing: -0.02em;
}

.about__highlight-label {
  font-size: 0.78rem;
  color: hsl(var(--muted-fg));
  margin-top: 4px;
}

/* ===== Skills / Core Strengths ===== */
.strengths__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-top: 48px;
}

.strength-card {
  padding: 28px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 16px;
  backdrop-filter: blur(4px);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.strength-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, hsl(var(--primary)), hsl(var(--accent)));
  opacity: 0;
  transition: opacity 0.3s ease;
}

.strength-card:hover {
  border-color: rgba(150, 150, 150, 0.15);
  transform: translateY(-4px);
  box-shadow: 0 8px 35px -5px rgba(150, 150, 150, 0.15);
}

.strength-card:hover::before {
  opacity: 1;
}

.strength-card__icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
  color: hsl(var(--primary));
  font-size: 1.3rem;
}

.strength-card__title {
  font-size: 1.1rem;
  font-weight: 700;
  margin-bottom: 10px;
  letter-spacing: -0.01em;
}

.strength-card__desc {
  font-size: 0.88rem;
  color: hsl(var(--muted-fg));
  line-height: 1.7;
  margin-bottom: 16px;
}

.strength-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.strength-card__tag {
  padding: 4px 12px;
  border-radius: 6px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  font-size: 0.75rem;
  font-weight: 500;
  color: hsl(var(--muted-fg));
  transition: all 0.2s ease;
}

.strength-card__tag:hover {
  color: hsl(var(--primary));
  border-color: rgba(150, 150, 150, 0.15);
}

/* ===== Projects / Solutions ===== */
.projects__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
  gap: 24px;
  margin-top: 48px;
}

.project-card {
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 16px;
  backdrop-filter: blur(4px);
  overflow: hidden;
  transition: all 0.3s ease;
  animation: fadeIn 0.6s ease-out forwards;
  opacity: 0;
}

.project-card:hover {
  border-color: rgba(150, 150, 150, 0.15);
  transform: translateY(-4px);
  box-shadow: 0 8px 40px -10px rgba(150, 150, 150, 0.15);
}

.project-card__preview {
  height: 180px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.project-card__emoji {
  font-size: 3.5rem;
  filter: drop-shadow(0 4px 20px rgba(0, 0, 0, 0.5));
  z-index: 1;
}

.project-card__preview::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60px;
  background: linear-gradient(to top, rgba(150, 150, 150, 0.15), transparent);
}

.project-card__body {
  padding: 24px;
}

.project-card__number {
  font-size: 0.78rem;
  font-weight: 700;
  color: hsl(var(--primary));
  font-family: monospace;
  letter-spacing: 0.05em;
}

.project-card__title {
  font-size: 1.2rem;
  font-weight: 700;
  margin: 8px 0 4px;
  letter-spacing: -0.01em;
}

.project-card__subtitle {
  font-size: 0.82rem;
  color: hsl(var(--primary));
  font-weight: 500;
  margin-bottom: 12px;
}

.project-card__desc {
  font-size: 0.88rem;
  color: hsl(var(--muted-fg));
  line-height: 1.7;
  margin-bottom: 16px;
}

.project-card__footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.project-card__tech {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.project-card__tag {
  padding: 4px 10px;
  border-radius: 6px;
  background: rgba(150, 150, 150, 0.15);
  color: hsl(var(--primary));
  font-size: 0.72rem;
  font-weight: 500;
  border: 1px solid rgba(150, 150, 150, 0.15);
}

.project-card__links {
  display: flex;
  gap: 8px;
}

.project-card__links a {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  border: 1px solid rgba(150, 150, 150, 0.15);
  color: hsl(var(--muted-fg));
  transition: all 0.2s ease;
}

.project-card__links a:hover {
  color: hsl(var(--primary));
  border-color: rgba(150, 150, 150, 0.15);
  background: rgba(150, 150, 150, 0.15);
}

/* ===== Experience ===== */
.experience__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  margin-top: 48px;
}

.exp-column__header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 32px;
}

.exp-column__icon {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  color: hsl(var(--primary));
}

.exp-column__title {
  font-size: 1.1rem;
  font-weight: 700;
}

.exp-item {
  position: relative;
  padding-left: 28px;
  margin-bottom: 32px;
}

.exp-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 6px;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: hsl(var(--primary));
  border: 3px solid hsl(var(--bg));
  box-shadow: 0 0 0 2px hsl(var(--primary));
}

.exp-item:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 5px;
  top: 22px;
  width: 2px;
  height: calc(100% + 8px);
  background: rgba(150, 150, 150, 0.15);
}

.exp-item__date {
  font-size: 0.78rem;
  font-weight: 600;
  color: hsl(var(--primary));
  letter-spacing: 0.05em;
}

.exp-item__role {
  font-size: 1.05rem;
  font-weight: 700;
  margin: 4px 0;
  letter-spacing: -0.01em;
}

.exp-item__company {
  font-size: 0.88rem;
  color: hsl(var(--muted-fg));
}

.exp-item__badge {
  display: inline-block;
  margin-top: 8px;
  padding: 4px 14px;
  background: rgba(150, 150, 150, 0.15);
  color: hsl(var(--primary));
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 600;
  border: 1px solid rgba(150, 150, 150, 0.15);
}

.exp-item__list {
  margin-top: 10px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.exp-item__list li {
  font-size: 0.85rem;
  color: hsl(var(--muted-fg));
  padding-left: 14px;
  position: relative;
  line-height: 1.6;
}

.exp-item__list li::before {
  content: 'â€º';
  position: absolute;
  left: 0;
  color: hsl(var(--primary));
  font-weight: 700;
}

/* ===== Achievements ===== */
.achievements__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-top: 48px;
}

.achievement-card {
  padding: 28px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 16px;
  backdrop-filter: blur(4px);
  transition: all 0.3s ease;
}

.achievement-card:hover {
  border-color: rgba(150, 150, 150, 0.15);
  transform: translateY(-2px);
  box-shadow: 0 0 20px -5px rgba(150, 150, 150, 0.15);
}

.achievement-card__header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 24px;
}

.achievement-card__icon {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
}

.achievement-card__icon--teal {
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  color: hsl(var(--primary));
}

.achievement-card__icon--violet {
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  color: hsl(var(--primary));
}

.achievement-card__category {
  font-size: 0.95rem;
  font-weight: 700;
}

.achievement-card__list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.achievement-item {
  padding: 14px 16px;
  border-radius: 10px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  transition: all 0.2s ease;
}

.achievement-item:hover {
  border-color: rgba(150, 150, 150, 0.15);
}

.achievement-item__title {
  font-size: 0.9rem;
  font-weight: 600;
}

.achievement-item__desc {
  font-size: 0.8rem;
  color: hsl(var(--muted-fg));
  margin-top: 4px;
  line-height: 1.5;
}

.achievement-item__date {
  font-size: 0.72rem;
  color: hsl(var(--primary));
  margin-top: 6px;
  font-weight: 500;
  display: inline-block;
}

/* ===== Contact ===== */
/* ===== Contact â€” mostaim.info inspired ===== */
.ct__grid {
  display: grid;
  grid-template-columns: 1fr 1.3fr;
  gap: 48px;
  align-items: start;
}

/* â”€â”€ Info column â”€â”€ */
.ct__info {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.ct__info-link {
  text-decoration: none;
  color: inherit;
}

.ct__info-card {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 20px 22px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 16px;
  transition: all 0.3s ease;
}

[data-theme="dark"] .ct__info-card {
  background: rgba(255, 255, 255, 0.03);
  border-color: rgba(255, 255, 255, 0.06);
}

.ct__info-card:hover {
  border-color: var(--ct-accent, hsl(var(--primary)));
  background: rgba(150, 150, 150, 0.15);
  transform: translateY(-2px);
  box-shadow: 0 8px 25px -6px rgba(150, 150, 150, 0.15);
}

[data-theme="dark"] .ct__info-card:hover {
  background: rgba(255, 255, 255, 0.05);
  box-shadow: 0 8px 25px -6px rgba(0, 0, 0, 0.3);
}

.ct__info-icon {
  width: 44px;
  height: 44px;
  min-width: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12px;
  background: color-mix(in srgb, var(--ct-accent, #2dd4bf) 12%, transparent);
  color: var(--ct-accent, #2dd4bf);
}

.ct__info-label {
  font-size: 0.72rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: rgba(156, 163, 175, 0.6);
  margin-bottom: 4px;
}

.ct__info-value {
  font-size: 0.92rem;
  font-weight: 500;
  color: hsl(var(--fg));
  line-height: 1.5;
}

[data-theme="dark"] .ct__info-value {
  color: #f3f4f6;
}

/* â”€â”€ Social buttons â”€â”€ */
.ct__socials {
  display: flex;
  gap: 12px;
  margin-top: 8px;
}

.ct__social-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1;
  justify-content: center;
  padding: 14px 20px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 14px;
  font-size: 0.85rem;
  font-weight: 500;
  color: hsl(var(--muted-fg));
  transition: all 0.3s ease;
  text-decoration: none;
}

[data-theme="dark"] .ct__social-btn {
  background: rgba(255, 255, 255, 0.03);
  border-color: rgba(255, 255, 255, 0.06);
  color: #9ca3af;
}

.ct__social-btn:hover {
  border-color: rgba(45, 212, 191, 0.3);
  color: #2dd4bf;
  transform: translateY(-2px);
  box-shadow: 0 6px 20px -4px rgba(45, 212, 191, 0.15);
}

/* â”€â”€ Form card â”€â”€ */
.ct__form-card {
  padding: 36px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 20px;
  backdrop-filter: blur(8px);
}

[data-theme="dark"] .ct__form-card {
  background: rgba(255, 255, 255, 0.03);
  border-color: rgba(255, 255, 255, 0.06);
}

.ct__form-heading {
  font-size: 1.25rem;
  font-weight: 700;
  color: hsl(var(--fg));
  margin-bottom: 4px;
}

[data-theme="dark"] .ct__form-heading {
  color: #f3f4f6;
}

.ct__form-subtitle {
  font-size: 0.82rem;
  color: rgba(156, 163, 175, 0.6);
  margin-bottom: 28px;
}

.ct__form {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

/* â”€â”€ Icon-prefixed fields â”€â”€ */
.ct__field {
  position: relative;
  display: flex;
  align-items: center;
}

.ct__field-icon {
  position: absolute;
  left: 16px;
  color: rgba(156, 163, 175, 0.45);
  pointer-events: none;
  z-index: 1;
  transition: color 0.25s ease;
}

.ct__field input,
.ct__field textarea {
  width: 100%;
  padding: 15px 16px 15px 48px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 14px;
  color: hsl(var(--fg));
  font-family: var(--font);
  font-size: 0.9rem;
  outline: none;
  transition: all 0.25s ease;
}

[data-theme="dark"] .ct__field input,
[data-theme="dark"] .ct__field textarea {
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(255, 255, 255, 0.08);
  color: #f3f4f6;
}

.ct__field input:focus,
.ct__field textarea:focus {
  border-color: rgba(45, 212, 191, 0.5);
  box-shadow: 0 0 0 3px rgba(45, 212, 191, 0.08);
  background: rgba(255, 255, 255, 0.06);
}

.ct__field:focus-within .ct__field-icon {
  color: #2dd4bf;
}

.ct__field input::placeholder,
.ct__field textarea::placeholder {
  color: rgba(156, 163, 175, 0.4);
}

.ct__field--textarea {
  align-items: flex-start;
}

.ct__field--textarea .ct__field-icon {
  top: 17px;
}

.ct__field textarea {
  resize: vertical;
  min-height: 120px;
}

/* â”€â”€ Submit button â”€â”€ */
.ct__submit {
  width: 100%;
  padding: 16px;
  background: linear-gradient(135deg, #3b82f6, #2dd4bf);
  border: none;
  border-radius: 14px;
  color: #fff;
  font-family: var(--font);
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  transition: all 0.3s ease;
  box-shadow: 0 4px 20px -4px rgba(45, 212, 191, 0.4);
}

.ct__submit:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 30px -4px rgba(45, 212, 191, 0.5);
}

.ct__submit:active {
  transform: translateY(0);
}

.ct__submit:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
}

.ct__privacy {
  font-size: 0.75rem;
  color: rgba(156, 163, 175, 0.45);
  text-align: center;
}

.ct__success {
  color: #22C55E;
  font-size: 0.88rem;
  font-weight: 500;
  text-align: center;
  padding: 12px;
  background: rgba(34, 197, 94, 0.08);
  border: 1px solid rgba(34, 197, 94, 0.15);
  border-radius: 12px;
}


/* ===== Footer ===== */
/* ===== Footer â€” mostaim-style 4-col ===== */
.ft {
  position: relative;
  padding: 64px 0 0;
  background: hsl(var(--bg));
  overflow: hidden;
}

[data-theme="dark"] .ft {
  background: #060a10;
}

.ft__glow {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, #2dd4bf, #3b82f6, transparent);
  opacity: 0.6;
}

/* Grid */
.ft__grid {
  display: grid;
  grid-template-columns: 1.4fr 0.8fr 1fr 1fr;
  gap: 48px;
  padding-bottom: 48px;
}

/* Column titles */
.ft__col-title {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.88rem;
  font-weight: 700;
  color: hsl(var(--fg));
  margin-bottom: 20px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

[data-theme="dark"] .ft__col-title {
  color: #f3f4f6;
}

.ft__col-bar {
  display: inline-block;
  width: 3px;
  height: 18px;
  border-radius: 2px;
  background: #2dd4bf;
}

.ft__col-bar--blue {
  background: #60a5fa;
}

/* â”€â”€ Col 1: Identity â”€â”€ */
.ft__brand {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 14px;
}

.ft__brand-icon {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12px;
  background: rgba(45, 212, 191, 0.1);
  color: #2dd4bf;
}

.ft__brand-name {
  font-size: 1.2rem;
  font-weight: 800;
  color: hsl(var(--fg));
  letter-spacing: -0.02em;
}

[data-theme="dark"] .ft__brand-name {
  color: #f3f4f6;
}

.ft__brand-highlight {
  background: linear-gradient(135deg, #60a5fa, #2dd4bf);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.ft__role {
  font-size: 0.78rem;
  font-weight: 600;
  color: #2dd4bf;
  margin-bottom: 12px;
  letter-spacing: 0.02em;
}

.ft__desc {
  font-size: 0.82rem;
  color: rgba(156, 163, 175, 0.7);
  line-height: 1.7;
}

/* â”€â”€ Col 2: Quick Links â”€â”€ */
.ft__nav {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.ft__nav-link {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 6px 0;
  font-size: 0.82rem;
  color: rgba(156, 163, 175, 0.7);
  text-decoration: none;
  transition: all 0.25s ease;
}

.ft__nav-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: rgba(156, 163, 175, 0.3);
  transition: all 0.25s ease;
}

.ft__nav-link:hover {
  color: #2dd4bf;
  transform: translateX(4px);
}

.ft__nav-link:hover .ft__nav-dot {
  background: #2dd4bf;
  box-shadow: 0 0 6px rgba(45, 212, 191, 0.4);
}

/* â”€â”€ Col 3: Connect â”€â”€ */
.ft__socials-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 16px;
}

.ft__social-card {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 16px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 12px;
  color: hsl(var(--muted-fg));
  text-decoration: none;
  font-size: 0.78rem;
  font-weight: 500;
  transition: all 0.3s ease;
}

[data-theme="dark"] .ft__social-card {
  background: rgba(255, 255, 255, 0.025);
  border-color: rgba(255, 255, 255, 0.05);
  color: rgba(156, 163, 175, 0.7);
}

.ft__social-card:hover {
  border-color: rgba(45, 212, 191, 0.25);
  color: #2dd4bf;
  transform: translateY(-3px);
  box-shadow: 0 8px 24px -6px rgba(45, 212, 191, 0.12);
  background: rgba(45, 212, 191, 0.04);
}

.ft__social-label {
  font-size: 0.75rem;
}

.ft__social-hint {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.72rem;
  color: rgba(156, 163, 175, 0.45);
}

/* â”€â”€ Col 4: Stay Informed â”€â”€ */
.ft__info-box {
  padding: 18px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 14px;
  margin-bottom: 16px;
}

[data-theme="dark"] .ft__info-box {
  background: rgba(255, 255, 255, 0.025);
  border-color: rgba(255, 255, 255, 0.05);
}

.ft__info-box p {
  font-size: 0.8rem;
  color: rgba(156, 163, 175, 0.65);
  line-height: 1.7;
}

.ft__cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 22px;
  background: linear-gradient(135deg, #3b82f6, #2dd4bf);
  border: none;
  border-radius: 10px;
  color: #fff;
  font-size: 0.82rem;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.3s ease;
  box-shadow: 0 4px 16px -4px rgba(45, 212, 191, 0.3);
}

.ft__cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px -4px rgba(45, 212, 191, 0.4);
}

/* â”€â”€ Bottom Bar â”€â”€ */
.ft__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 0;
  border-top: 1px solid rgba(150, 150, 150, 0.15);
  font-size: 0.75rem;
  color: hsl(var(--muted-fg));
}

[data-theme="dark"] .ft__bottom {
  border-top-color: rgba(255, 255, 255, 0.06);
  color: rgba(156, 163, 175, 0.5);
}

.ft__bottom-center {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.ft__back-top {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  color: hsl(var(--muted-fg));
  cursor: pointer;
  transition: all 0.3s ease;
}

[data-theme="dark"] .ft__back-top {
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(255, 255, 255, 0.08);
  color: rgba(156, 163, 175, 0.6);
}

.ft__back-top:hover {
  background: rgba(45, 212, 191, 0.08);
  border-color: rgba(45, 212, 191, 0.25);
  color: #2dd4bf;
  transform: translateY(-2px);
}

/* ===== Section Backgrounds ===== */
.section--alt {
  background: transparent;
}

.section-bg-subtle {
  background: linear-gradient(to bottom, hsl(var(--bg)), rgba(150, 150, 150, 0.15), hsl(var(--bg)));
}

[data-theme="dark"] .section-bg-subtle {
  background: linear-gradient(to bottom, hsl(var(--bg)), rgba(150, 150, 150, 0.15), hsl(var(--bg)));
}



[data-theme="dark"] .about__image-glow {
  opacity: 0.4;
}

/* ===== Animations ===== */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes float {

  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-20px);
  }
}

/* ===== Responsive Improvements ===== */
@media (max-width: 1200px) {
  .hero__layout {
    gap: 2rem;
    padding: 120px 2rem 80px;
  }
}

@media (max-width: 1024px) {
  .hero__layout {
    grid-template-columns: 1fr;
    text-align: center;
    gap: 3rem;
  }

  .about__grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .ft__grid {
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }

  .skills__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .nav-top {
    display: none;
  }

  .section {
    padding: 60px 0;
  }

  .section__title {
    font-size: 2rem;
  }

  .hero__layout {
    padding-top: 100px;
  }

  .ft__grid {
    grid-template-columns: 1fr 1fr;
    gap: 30px;
  }

  .ft__bottom {
    flex-direction: column;
    gap: 16px;
    text-align: center;
  }

  .ft__bottom-center {
    position: static;
    transform: none;
    order: 2;
  }

  .skills__grid {
    grid-template-columns: 1fr;
    gap: 20px;
  }
}

@media (max-width: 640px) {
  .ft__grid {
    grid-template-columns: 1fr;
    gap: 32px;
  }

  .ft__socials-grid {
    grid-template-columns: 1fr;
  }

  .container {
    padding: 0 1.25rem;
  }
}

@media (max-width: 480px) {
  .section__title {
    font-size: 1.75rem;
  }

  .hero__welcome-badge {
    font-size: 0.75rem;
    padding: 6px 12px;
  }
}

/* ===== Articles & Gallery Pages ===== */

/* -- Shared Hero -- */
.articles-hero,
.gallery-hero {
  position: relative;
  padding: 140px 0 60px;
  overflow: hidden;
  background: hsl(var(--bg));
}

.articles-hero__bg,
.gallery-hero__bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 20% 50%, rgba(150, 150, 150, 0.15) 0%, transparent 60%),
    radial-gradient(ellipse at 80% 50%, rgba(45, 212, 191, 0.04) 0%, transparent 60%);
  pointer-events: none;
}

.articles-hero__back {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.82rem;
  font-weight: 500;
  color: hsl(var(--muted-fg));
  text-decoration: none;
  margin-bottom: 24px;
  transition: color 0.25s ease;
}

.articles-hero__back:hover {
  color: hsl(var(--primary));
}

.articles-hero__badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 999px;
  color: hsl(var(--primary));
  font-size: 0.78rem;
  font-weight: 600;
  margin-bottom: 20px;
}

.articles-hero__title,
.gallery-hero__title {
  font-family: var(--font);
  font-size: 3rem;
  font-weight: 900;
  letter-spacing: -0.03em;
  line-height: 1.1;
  color: hsl(var(--fg));
  margin-bottom: 16px;
}

.gradient-text {
  background: linear-gradient(135deg, #60a5fa, #2dd4bf);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.articles-hero__desc,
.gallery-hero__desc {
  font-size: 1rem;
  color: hsl(var(--muted-fg));
  line-height: 1.7;
  max-width: 520px;
}

[data-theme="dark"] .articles-hero__desc,
[data-theme="dark"] .gallery-hero__desc {
  color: rgba(209, 213, 219, 0.7);
}

/* -- Filter Pills -- */
.articles-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 40px;
}

.articles-filter-pill {
  padding: 8px 20px;
  border-radius: 999px;
  font-size: 0.82rem;
  font-weight: 600;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  color: hsl(var(--muted-fg));
  cursor: pointer;
  transition: all 0.25s ease;
  font-family: var(--font);
}

.articles-filter-pill:hover {
  border-color: rgba(150, 150, 150, 0.15);
  color: hsl(var(--primary));
}

.articles-filter-pill--active {
  background: linear-gradient(135deg, #3b82f6, #2dd4bf);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 4px 16px -4px rgba(45, 212, 191, 0.3);
}

[data-theme="dark"] .articles-filter-pill {
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(255, 255, 255, 0.08);
  color: rgba(209, 213, 219, 0.7);
}

[data-theme="dark"] .articles-filter-pill:hover {
  border-color: rgba(45, 212, 191, 0.3);
  color: #2dd4bf;
}

/* -- Articles Grid -- */
.articles-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 28px;
}

@media (max-width: 768px) {
  .articles-grid {
    grid-template-columns: 1fr;
  }
}

/* -- Article Card -- */
.article-card {
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 18px;
  overflow: hidden;
  text-decoration: none;
  transition: all 0.35s ease;
  backdrop-filter: blur(12px);
  display: flex;
  flex-direction: column;
}

[data-theme="dark"] .article-card {
  background: rgba(10, 20, 40, 0.5);
  border-color: rgba(255, 255, 255, 0.06);
}

.article-card:hover {
  border-color: rgba(150, 150, 150, 0.15);
  transform: translateY(-6px);
  box-shadow:
    0 20px 50px -12px rgba(150, 150, 150, 0.15),
    0 0 0 1px rgba(150, 150, 150, 0.15);
}

.article-card__image {
  position: relative;
  height: 200px;
  overflow: hidden;
  background: rgba(150, 150, 150, 0.15);
}

.article-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.article-card:hover .article-card__image img {
  transform: scale(1.08);
}

.article-card__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(150, 150, 150, 0.15), rgba(45, 212, 191, 0.06));
  color: hsl(var(--muted-fg));
}

.article-card__category {
  position: absolute;
  top: 14px;
  left: 14px;
  padding: 5px 14px;
  border-radius: 999px;
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  background: rgba(0, 0, 0, 0.55);
  backdrop-filter: blur(8px);
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.article-card__category--inline {
  position: static;
  display: inline-flex;
  margin-bottom: 12px;
  background: rgba(150, 150, 150, 0.15);
  color: hsl(var(--primary));
  border: 1px solid rgba(150, 150, 150, 0.15);
}

.article-card__body {
  padding: 24px;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.article-card__title {
  font-size: 1.15rem;
  font-weight: 700;
  color: hsl(var(--fg));
  line-height: 1.35;
  margin-bottom: 10px;
  letter-spacing: -0.01em;
}

[data-theme="dark"] .article-card__title {
  color: #f3f4f6;
}

.article-card__excerpt {
  font-size: 0.85rem;
  color: hsl(var(--muted-fg));
  line-height: 1.65;
  margin-bottom: 16px;
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

[data-theme="dark"] .article-card__excerpt {
  color: rgba(156, 163, 175, 0.7);
}

.article-card__meta {
  display: flex;
  gap: 16px;
  margin-bottom: 16px;
}

.article-card__meta-item {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 0.75rem;
  font-weight: 500;
  color: hsl(var(--muted-fg));
}

[data-theme="dark"] .article-card__meta-item {
  color: rgba(156, 163, 175, 0.6);
}

.article-card__meta-item svg {
  color: #2dd4bf;
}

.article-card__read-more {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.82rem;
  font-weight: 600;
  color: hsl(var(--primary));
  margin-top: auto;
  transition: gap 0.25s ease;
}

.article-card:hover .article-card__read-more {
  gap: 10px;
}

/* -- Empty & Loading States -- */
.articles-empty {
  text-align: center;
  padding: 80px 20px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px dashed rgba(150, 150, 150, 0.15);
  border-radius: 20px;
}

[data-theme="dark"] .articles-empty {
  background: rgba(255, 255, 255, 0.02);
  border-color: rgba(255, 255, 255, 0.06);
}

.articles-empty__icon {
  font-size: 3rem;
  margin-bottom: 16px;
}

.articles-empty h3 {
  font-size: 1.3rem;
  color: hsl(var(--fg));
  margin-bottom: 8px;
}

.articles-empty p {
  font-size: 0.9rem;
  color: hsl(var(--muted-fg));
}

.articles-loading {
  text-align: center;
  padding: 80px 20px;
}

.articles-loading__spinner {
  width: 40px;
  height: 40px;
  border: 3px solid rgba(150, 150, 150, 0.15);
  border-top-color: hsl(var(--primary));
  border-radius: 50%;
  margin: 0 auto 16px;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.articles-loading p {
  font-size: 0.9rem;
  color: hsl(var(--muted-fg));
}

/* -- Article Detail -- */
.article-detail__header {
  position: relative;
  padding: 140px 0 50px;
  overflow: hidden;
  background: hsl(var(--bg));
}

.article-detail__header-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 30% 40%, rgba(150, 150, 150, 0.15) 0%, transparent 60%),
    radial-gradient(ellipse at 70% 60%, rgba(45, 212, 191, 0.04) 0%, transparent 60%);
  pointer-events: none;
}

.article-detail__title {
  font-family: var(--font);
  font-size: 2.6rem;
  font-weight: 900;
  letter-spacing: -0.03em;
  line-height: 1.15;
  color: hsl(var(--fg));
  margin-bottom: 16px;
}

[data-theme="dark"] .article-detail__title {
  color: #f3f4f6;
}

.article-detail__excerpt {
  font-size: 1.05rem;
  color: hsl(var(--muted-fg));
  line-height: 1.7;
  margin-bottom: 20px;
  max-width: 640px;
}

.article-detail__meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 16px;
}

.article-detail__share {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 16px;
  border-radius: 999px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  color: hsl(var(--primary));
  font-size: 0.78rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.25s ease;
  font-family: var(--font);
}

.article-detail__share:hover {
  background: rgba(150, 150, 150, 0.15);
}

.article-detail__cover {
  margin-top: -20px;
  margin-bottom: 40px;
}

.article-detail__cover img {
  width: 100%;
  max-height: 450px;
  object-fit: cover;
  border-radius: 18px;
  border: 1px solid rgba(150, 150, 150, 0.15);
}

.article-detail__body {
  padding-bottom: 60px;
}

.article-detail__content {
  max-width: 740px;
  margin: 0 auto;
  font-size: 1rem;
  line-height: 1.85;
  color: hsl(var(--fg));
}

[data-theme="dark"] .article-detail__content {
  color: rgba(229, 231, 235, 0.9);
}

.article-detail__content h2 {
  font-size: 1.5rem;
  font-weight: 800;
  margin: 40px 0 16px;
  color: hsl(var(--fg));
}

.article-detail__content h3 {
  font-size: 1.2rem;
  font-weight: 700;
  margin: 32px 0 12px;
}

.article-detail__content p {
  margin-bottom: 20px;
}

.article-detail__content img {
  width: 100%;
  border-radius: 12px;
  margin: 24px 0;
}

.article-detail__content code {
  background: rgba(150, 150, 150, 0.15);
  padding: 2px 8px;
  border-radius: 6px;
  font-size: 0.88rem;
  color: hsl(var(--primary));
}

.article-detail__content pre {
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 12px;
  padding: 20px 24px;
  overflow-x: auto;
  margin: 24px 0;
}

[data-theme="dark"] .article-detail__content pre {
  background: rgba(10, 20, 40, 0.6);
  border-color: rgba(255, 255, 255, 0.06);
}

.article-detail__content pre code {
  background: none;
  padding: 0;
  color: inherit;
}

.article-detail__content blockquote {
  border-left: 3px solid #2dd4bf;
  padding: 12px 20px;
  margin: 24px 0;
  background: rgba(150, 150, 150, 0.15);
  border-radius: 0 12px 12px 0;
  font-style: italic;
  color: hsl(var(--muted-fg));
}

.article-detail__content ul,
.article-detail__content ol {
  padding-left: 24px;
  margin-bottom: 20px;
}

.article-detail__content li {
  margin-bottom: 8px;
}

.article-detail__footer {
  padding: 40px 0 80px;
  text-align: center;
}

.article-detail-loading,
.article-detail-empty {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  padding: 40px;
}

.article-detail-empty h2 {
  font-size: 1.5rem;
  color: hsl(var(--fg));
}

.article-detail-empty p {
  color: hsl(var(--muted-fg));
  margin-bottom: 16px;
}

/* ===== Gallery Grid ===== */
.gallery-grid {
  columns: 3;
  column-gap: 20px;
}

@media (max-width: 1024px) {
  .gallery-grid {
    columns: 2;
  }
}

@media (max-width: 640px) {
  .gallery-grid {
    columns: 1;
  }
}

.gallery-card {
  position: relative;
  break-inside: avoid;
  margin-bottom: 20px;
  border-radius: 16px;
  overflow: hidden;
  cursor: pointer;
  border: 1px solid rgba(150, 150, 150, 0.15);
  transition: all 0.35s ease;
}

[data-theme="dark"] .gallery-card {
  border-color: rgba(255, 255, 255, 0.06);
}

.gallery-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 40px -8px rgba(0, 0, 0, 0.2);
  border-color: rgba(150, 150, 150, 0.15);
}

.gallery-card img {
  width: 100%;
  display: block;
  transition: transform 0.5s ease;
}

.gallery-card:hover img {
  transform: scale(1.06);
}

.gallery-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.75) 0%, transparent 60%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 20px;
  opacity: 0;
  transition: opacity 0.35s ease;
}

.gallery-card:hover .gallery-card__overlay {
  opacity: 1;
}

.gallery-card__multi-indicator {
  position: absolute;
  top: 15px;
  right: 15px;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4px);
  color: white;
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 6px;
  z-index: 2;
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.gallery-card__category {
  display: inline-flex;
  align-self: flex-start;
  padding: 4px 12px;
  border-radius: 999px;
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  background: rgba(45, 212, 191, 0.2);
  color: #2dd4bf;
  border: 1px solid rgba(45, 212, 191, 0.3);
  margin-bottom: 8px;
}

.gallery-card__title {
  font-size: 1rem;
  font-weight: 700;
  color: #fff;
  margin-bottom: 4px;
}

.gallery-card__desc {
  font-size: 0.78rem;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ===== Lightbox ===== */
.lightbox {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.92);
  backdrop-filter: blur(20px);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: lightboxFadeIn 0.3s ease;
}

@keyframes lightboxFadeIn {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

.lightbox__content {
  position: relative;
  max-width: 90vw;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.lightbox__image {
  max-width: 100%;
  max-height: 75vh;
  object-fit: contain;
  border-radius: 12px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
}

.lightbox__close {
  position: absolute;
  top: -50px;
  right: 0;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  cursor: pointer;
  transition: all 0.25s ease;
}

.lightbox__close:hover {
  background: rgba(255, 255, 255, 0.2);
  transform: rotate(90deg);
}

.lightbox__nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 50%;
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  cursor: pointer;
  transition: all 0.25s ease;
}

.lightbox__nav:hover {
  background: rgba(255, 255, 255, 0.18);
}

.lightbox__nav--prev {
  left: -70px;
}

.lightbox__nav--next {
  right: -70px;
}

.lightbox__info {
  text-align: center;
  margin-top: 20px;
  color: #fff;
}

.lightbox__info h3 {
  font-size: 1.1rem;
  font-weight: 700;
  margin-bottom: 4px;
}

.lightbox__info p {
  font-size: 0.85rem;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 8px;
}

.lightbox__counter {
  font-size: 0.75rem;
  color: rgba(255, 255, 255, 0.4);
  font-weight: 600;
}

/* -- Responsive adjustments for lightbox -- */
@media (max-width: 768px) {
  .lightbox__nav--prev {
    left: 10px;
  }

  .lightbox__nav--next {
    right: 10px;
  }

  .lightbox__nav {
    width: 40px;
    height: 40px;
  }

  .lightbox__close {
    top: -45px;
    right: 10px;
  }

  .articles-hero__title,
  .gallery-hero__title {
    font-size: 2.2rem;
  }

  .article-detail__title {
    font-size: 2rem;
  }
}

/* ===== Admin â€” New Elements (CMS Expansion) ===== */

/* Gallery card in admin list */
.admin__card--gallery {
  display: flex;
  align-items: flex-start;
  gap: 16px;
}

.admin__gallery-thumb {
  width: 80px;
  height: 80px;
  border-radius: 10px;
  object-fit: cover;
  flex-shrink: 0;
  border: 1px solid rgba(150, 150, 150, 0.15);
}

/* Profile form layout */
.admin__form--profile {
  max-width: 100%;
}

.admin__form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  margin-bottom: 24px;
}

@media (max-width: 768px) {
  .admin__form-grid {
    grid-template-columns: 1fr;
  }
}

.admin__form-section {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 20px;
}

.admin__form-section-title {
  font-size: 0.9rem;
  font-weight: 700;
  color: hsl(var(--primary));
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: 4px;
  padding-bottom: 6px;
  border-bottom: 1px solid rgba(150, 150, 150, 0.15);
}

.admin__form-section label {
  font-size: 0.82rem;
  font-weight: 600;
  color: hsl(var(--muted-fg));
  margin-top: 4px;
}

.admin__form-section code {
  font-size: 0.78rem;
  background: rgba(150, 150, 150, 0.15);
  padding: 2px 6px;
  border-radius: 4px;
}

/* ===== Premium Admin CMS Layout (Matching Frontend Aesthetics) ===== */
.admin {
  display: flex;
  min-height: 100vh;
  /* Use the exact premium gradient from the Hero */
  background: linear-gradient(135deg, #e8e0f3 0%, #f0f4f8 40%, #f8fafc 100%);
  font-family: var(--font);
  color: hsl(var(--fg));
}

[data-theme="dark"] .admin {
  background: linear-gradient(135deg, #1f0f3d 0%, #0c0c12 40%, #0c0c12 100%);
}

/* Sidebar â€” Floating Glass Panel */
.admin__sidebar {
  width: 280px;
  margin: 24px;
  border-radius: 24px;
  background: rgba(150, 150, 150, 0.15);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(150, 150, 150, 0.15);
  display: flex;
  flex-direction: column;
  padding: 30px 24px;
  position: sticky;
  top: 24px;
  height: calc(100vh - 48px);
  box-shadow: 0 20px 40px rgba(150, 150, 150, 0.15);
}

.admin__sidebar-header {
  margin-bottom: 40px;
}

.admin__back {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.85rem;
  font-weight: 600;
  color: hsl(var(--muted-fg));
  margin-bottom: 20px;
  transition: all 0.3s ease;
}

.admin__back:hover {
  color: hsl(var(--primary));
  transform: translateX(-4px);
}

.admin__sidebar-header h2 {
  font-size: 1.6rem;
  font-weight: 800;
  letter-spacing: -0.03em;
  background: linear-gradient(90deg, hsl(var(--primary)), hsl(var(--accent)));
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.admin__nav {
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}

.admin__nav-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-align: left;
  padding: 14px 18px;
  border-radius: 14px;
  background: transparent;
  border: 1px solid transparent;
  color: hsl(var(--muted-fg));
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.admin__nav-btn:hover {
  background: rgba(150, 150, 150, 0.15);
  color: hsl(var(--fg));
  transform: translateX(4px);
}

.admin__nav-btn--active {
  /* Premium Active State */
  background: linear-gradient(to right, rgba(150, 150, 150, 0.15), rgba(150, 150, 150, 0.15));
  border: 1px solid rgba(150, 150, 150, 0.15);
  color: hsl(var(--primary));
  box-shadow: inset 3px 0 0 0 hsl(var(--primary));
}

.admin__nav-btn--active:hover {
  transform: none;
}

.admin__badge {
  background: linear-gradient(135deg, hsl(var(--primary)), hsl(var(--accent)));
  color: #fff;
  font-size: 0.75rem;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 999px;
  line-height: 1;
  box-shadow: 0 4px 10px rgba(150, 150, 150, 0.15);
}

.admin__logout {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 18px;
  margin-top: auto;
  background: hsla(0, 80%, 50%, 0.05);
  border: 1px solid hsla(0, 80%, 50%, 0.1);
  color: hsl(0, 80%, 60%);
  font-weight: 600;
  cursor: pointer;
  border-radius: 14px;
  transition: all 0.3s ease;
}

.admin__logout:hover {
  background: hsla(0, 80%, 50%, 0.15);
  transform: translateY(-2px);
  box-shadow: 0 8px 20px hsla(0, 80%, 50%, 0.15);
}

.admin__main {
  flex: 1;
  padding: 40px 60px 80px 40px;
  max-width: 1300px;
}

.admin__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40px;
  position: relative;
}

.admin__header::after {
  content: '';
  position: absolute;
  bottom: -20px;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, rgba(150, 150, 150, 0.15), transparent);
}

.admin__header h1 {
  font-size: 2.5rem;
  font-weight: 800;
  letter-spacing: -0.03em;
  color: hsl(var(--fg));
}

/* Premium Form Design (Like Hero Editor) */
.admin__form {
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  padding: 32px;
  border-radius: 20px;
  margin-bottom: 40px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow: 0 20px 40px rgba(150, 150, 150, 0.15);
  position: relative;
}

/* Editor Dots (Mac OS style) for forms */
.admin__form::before {
  content: '';
  position: absolute;
  top: 14px;
  left: 20px;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: #ef4444;
  box-shadow: 16px 0 0 #f59e0b, 32px 0 0 #10b981;
}

.admin__form {
  padding-top: 40px;
}

.admin__form input,
.admin__form textarea,
.admin__form select {
  width: 100%;
  padding: 14px 18px;
  border-radius: 12px;
  border: 1px solid rgba(150, 150, 150, 0.15);
  background: rgba(150, 150, 150, 0.15);
  color: hsl(var(--fg));
  font-family: var(--font);
  font-size: 0.95rem;
  transition: all 0.3s ease;
}

.admin__form input:focus,
.admin__form textarea:focus,
.admin__form select:focus {
  outline: none;
  border-color: hsl(var(--primary));
  box-shadow: 0 0 0 4px rgba(150, 150, 150, 0.15);
  background: hsl(var(--card));
  transform: translateY(-1px);
}

.admin__form--inline {
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
}

.admin__form--inline input,
.admin__form--inline select {
  width: auto;
  flex: 1;
}

/* CMS Premium Cards (Mirroring Skills.jsx & Projects.jsx) */
.admin__list {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
  gap: 24px;
}

.admin__card {
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 20px;
  padding: 24px;
  display: flex;
  flex-direction: column;
  transition: all 0.3s ease;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  position: relative;
  overflow: hidden;
}

.admin__card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 4px;
  background: linear-gradient(90deg, hsl(var(--primary)), hsl(var(--accent)));
  opacity: 0;
  transition: opacity 0.3s ease;
}

.admin__card:hover {
  border-color: hsl(var(--primary));
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(150, 150, 150, 0.15);
}

.admin__card:hover::before {
  opacity: 1;
}

.admin__card--inline {
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 16px 24px;
}

.admin__card-body {
  flex: 1;
  z-index: 1;
}

.admin__card h3 {
  font-size: 1.25rem;
  font-weight: 700;
  margin-bottom: 10px;
  color: hsl(var(--fg));
}

.admin__card p {
  font-size: 0.95rem;
  color: hsl(var(--muted-fg));
  margin-bottom: 16px;
  line-height: 1.6;
}

/* Matching the project tag pills */
.admin__card-meta,
.admin__card-tags span {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 6px 14px;
  border-radius: 999px;
  background: rgba(150, 150, 150, 0.15);
  border: 1px solid rgba(150, 150, 150, 0.15);
  font-size: 0.8rem;
  font-weight: 600;
  color: hsl(var(--primary));
}

.admin__card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.admin__card-actions {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: 20px;
  padding-top: 16px;
  border-top: 1px dashed rgba(150, 150, 150, 0.15);
  z-index: 1;
}

.admin__card--inline .admin__card-actions {
  margin-top: 0;
  padding-top: 0;
  border-top: none;
}

.admin__card-actions button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 10px;
  border: 1px solid rgba(150, 150, 150, 0.15);
  background: rgba(150, 150, 150, 0.15);
  color: hsl(var(--muted-fg));
  cursor: pointer;
  transition: all 0.2s ease;
}

.admin__card-actions button:hover {
  background: hsl(var(--primary));
  color: #fff;
  border-color: hsl(var(--primary));
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(150, 150, 150, 0.15);
}

.admin__card-actions button:last-child:hover {
  background: #ef4444;
  color: white;
  border-color: #ef4444;
  box-shadow: 0 4px 12px hsla(0, 80%, 50%, 0.3);
}

/* Unread Messages Glow */
.admin__card--unread {
  border-left: 4px solid hsl(var(--primary));
  background: linear-gradient(to right, rgba(150, 150, 150, 0.15), rgba(150, 150, 150, 0.15));
  box-shadow: 0 0 20px rgba(150, 150, 150, 0.15);
}

.skill-tag {
  font-weight: 700;
  font-size: 1.1rem;
  margin-right: 14px;
  color: hsl(var(--fg));
}

/* ===== Premium Login Layout ===== */
.login {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e8e0f3 0%, #f0f4f8 40%, #f8fafc 100%);
  padding: 20px;
  position: relative;
  overflow: hidden;
}

[data-theme="dark"] .login {
  background: linear-gradient(135deg, #1f0f3d 0%, #0c0c12 40%, #0c0c12 100%);
}

.login::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at center, rgba(150, 150, 150, 0.15) 0%, transparent 60%);
  pointer-events: none;
}

.login__card {
  position: relative;
  width: 100%;
  max-width: 420px;
  background: rgba(150, 150, 150, 0.15);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(150, 150, 150, 0.15);
  border-radius: 24px;
  padding: 48px 40px;
  box-shadow: 0 30px 60px rgba(150, 150, 150, 0.15), 0 0 0 1px rgba(150, 150, 150, 0.15);
  z-index: 10;
  text-align: center;
}

.login__header h1 {
  font-size: 2rem;
  font-weight: 800;
  letter-spacing: -0.03em;
  margin-bottom: 8px;
  background: linear-gradient(90deg, hsl(var(--primary)), hsl(var(--accent)));
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.login__header p {
  color: hsl(var(--muted-fg));
  font-size: 0.95rem;
  margin-bottom: 32px;
}

.login .form-group {
  margin-bottom: 20px;
  text-align: left;
}

.login .form-group label {
  display: block;
  font-size: 0.85rem;
  font-weight: 600;
  color: hsl(var(--fg));
  margin-bottom: 8px;
}

.login .form-group input {
  width: 100%;
  padding: 14px 18px;
  border-radius: 14px;
  border: 1px solid rgba(150, 150, 150, 0.15);
  background: rgba(150, 150, 150, 0.15);
  color: hsl(var(--fg));
  font-family: var(--font);
  font-size: 1rem;
  transition: all 0.3s ease;
}

.login .form-group input:focus {
  outline: none;
  border-color: hsl(var(--primary));
  box-shadow: 0 0 0 4px rgba(150, 150, 150, 0.15);
  background: hsl(var(--card));
}

.login__error {
  color: #ef4444;
  font-size: 0.85rem;
  margin-bottom: 20px;
  background: hsla(0, 80%, 50%, 0.1);
  padding: 10px;
  border-radius: 8px;
  border: 1px solid hsla(0, 80%, 50%, 0.2);
}

.login .btn--full {
  width: 100%;
  padding: 14px;
  border-radius: 14px;
  font-size: 1rem;
  margin-top: 10px;
  margin-bottom: 24px;
  background: linear-gradient(135deg, hsl(var(--primary)), hsl(var(--accent)));
  border: none;
  color: white;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 8px 20px rgba(150, 150, 150, 0.15);
}

.login .btn--full:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 25px rgba(150, 150, 150, 0.15);
}

.login__back {
  display: inline-block;
  color: hsl(var(--muted-fg));
  font-size: 0.85rem;
  font-weight: 600;
  transition: color 0.3s ease;
}

.login__back:hover {
  color: hsl(var(--primary));
}

/* ===== Medium Inspired Article Styles ===== */
.articles-page {
  background-color: var(--bg);
  min-height: 100vh;
}

.medium-reading-width {
  max-width: 680px;
  margin: 0 auto;
}

.articles-grid--medium {
  display: flex;
  flex-direction: column;
  gap: 3rem;
  max-width: 800px;
  margin: 0 auto;
}

.article-card--medium {
  display: flex;
  gap: 2rem;
  align-items: center;
  text-decoration: none;
  color: inherit;
  border-bottom: 1px solid rgba(150, 150, 150, 0.2);
  padding-bottom: 2rem;
}

@media (max-width: 768px) {
  .article-card--medium {
    flex-direction: column-reverse;
    align-items: flex-start;
  }
}

.article-card__body--medium {
  flex: 1;
}

.article-card__meta-author {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.9rem;
  color: hsl(var(--fg));
  margin-bottom: 8px;
}

.article-card__meta-author img {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  object-fit: cover;
}

.article-card__title--medium {
  font-size: 1.6rem;
  font-weight: 800;
  line-height: 1.25;
  margin-bottom: 8px;
  font-family: var(--font), sans-serif;
  color: hsl(var(--fg));
}

[data-theme="dark"] .article-card__title--medium {
  color: #f3f4f6;
}

.article-card__excerpt--medium {
  font-size: 1.05rem;
  color: hsl(var(--muted-fg));
  line-height: 1.5;
  margin-bottom: 16px;
  font-family: Georgia, serif;
}

[data-theme="dark"] .article-card__excerpt--medium {
  color: #d1d5db;
}

.article-card__meta-bottom {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 0.85rem;
  color: hsl(var(--muted-fg));
}

.article-card__meta-bottom span {
  display: inline-flex;
  align-items: center;
  gap: 4px;
}

.article-card__image-container--medium {
  width: 200px;
  height: 134px;
  flex-shrink: 0;
  border-radius: 4px;
  overflow: hidden;
  background-color: #f0f0f0;
}

@media (max-width: 768px) {
  .article-card__image-container--medium {
    width: 100%;
    height: 200px;
  }
}

.article-card__image-container--medium img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Article Detail (ArticleDetail.jsx) */
.article-detail--medium {
  padding-top: 100px;
  padding-bottom: 100px;
  background-color: var(--bg);
}

.article-detail__header--medium {
  text-align: left;
  margin-bottom: 2rem;
}

.article-detail__title--medium {
  font-size: 3rem;
  font-weight: 800;
  line-height: 1.1;
  color: hsl(var(--fg));
  margin-bottom: 1rem;
  font-family: var(--font), sans-serif;
}

@media (max-width: 768px) {
  .article-detail__title--medium {
    font-size: 2.2rem;
  }
}

.article-detail__subtitle--medium {
  font-size: 1.4rem;
  color: hsl(var(--muted-fg));
  font-family: var(--font), sans-serif;
  margin-bottom: 2rem;
  line-height: 1.4;
  font-weight: 400;
}

.article-detail__author-block {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 2rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid rgba(150, 150, 150, 0.2);
}

.article-detail__author-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  object-fit: cover;
}

.article-detail__author-info h4 {
  margin: 0 0 4px 0;
  font-size: 1rem;
  color: hsl(var(--fg));
  font-weight: 600;
}

.article-detail__author-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.9rem;
  color: hsl(var(--muted-fg));
}

.article-detail__author-actions {
  margin-left: auto;
  display: flex;
  gap: 12px;
}

.article-detail__action-btn {
  background: transparent;
  border: none;
  font-size: 0.95rem;
  color: hsl(var(--muted-fg));
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
  transition: color 0.2s;
}

.article-detail__action-btn:hover {
  color: hsl(var(--fg));
}

.article-detail__cover--medium {
  width: 100%;
  max-width: 1000px;
  margin: 0 auto 3rem auto;
  border-radius: 4px;
  overflow: hidden;
}

.article-detail__cover--medium img {
  width: 100%;
  height: auto;
  display: block;
}

.article-detail__content--medium {
  font-size: 1.25rem;
  line-height: 1.8;
  color: hsl(var(--fg));
  font-family: Georgia, Cambria, "Times New Roman", Times, serif;
}

[data-theme="dark"] .article-detail__content--medium {
  color: #e5e7eb;
}

.article-detail__content--medium p {
  margin-bottom: 2rem;
}

.article-detail__content--medium h2 {
  font-family: var(--font), sans-serif;
  font-size: 2rem;
  font-weight: 700;
  margin-top: 3rem;
  margin-bottom: 1rem;
}

.article-detail__content--medium h3 {
  font-family: var(--font), sans-serif;
  font-size: 1.5rem;
  font-weight: 700;
  margin-top: 2rem;
  margin-bottom: 1rem;
}

.article-detail__content--medium img {
  max-width: 100%;
  border-radius: 4px;
  margin: 2rem 0;
}

.article-detail__content--medium blockquote {
  border-left: 4px solid hsl(var(--primary));
  padding-left: 1.5rem;
  font-style: italic;
  font-size: 1.4rem;
  color: hsl(var(--muted-fg));
  margin: 2rem 0;
}

/* Admin Article Form Layout */
.admin-article-layout {
  display: flex;
  gap: 30px;
  align-items: flex-start;
}

@media (max-width: 900px) {
  .admin-article-layout {
    flex-direction: column;
  }
}

.admin-article-main {
  flex: 2;
  display: flex;
  flex-direction: column;
  gap: 20px;
  min-width: 0;
  width: 100%;
}

.admin-article-sidebar {
  flex: 1;
  background: var(--ta-surface);
  border: 1px solid var(--ta-border);
  border-radius: 12px;
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  position: sticky;
  top: 20px;
  min-width: 300px;
  width: 100%;
}

.admin-article-editor .ql-container {
  font-size: 1.1rem;
  font-family: Georgia, serif;
  min-height: 400px;
}

.admin-article-editor .ql-editor {
  min-height: 400px;
}